    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You can bond with up to two weapons. You cannot be disarmed of a bonded weapon, and you can summon one to your hand as a Bonus Action if it is on the same plane."
    }
  },
  {
