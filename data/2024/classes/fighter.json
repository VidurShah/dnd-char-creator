    "source": {
      "book": "PHB2024"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "When you hit a creature with a weapon, that creature has Disadvantage on the next saving throw it makes against a spell you cast before the end of your next turn."
    }
  },
  {
