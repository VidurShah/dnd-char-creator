  {
    "id": "2024/feature/battlemaster-combatsuperiority",
    "edition": "2024",
    "name": "Combat Superiority",
    "source": {
      "book": "PHB2024"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You learn maneuvers fueled by Superiority Dice (d8s). You have a number of these dice that you regain on a Short or Long Rest, and you learn additional maneuvers as you gain levels."
    }
  },
  {
    "id": "2024/feature/battlemaster-studentofwar",
