    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You augment your martial prowess with the ability to cast Wizard spells, drawn mostly from the Abjuration and Evocation schools. Intelligence is your spellcasting ability."
