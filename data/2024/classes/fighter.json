    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "As a Bonus Action, you can discern whether a creature you can see is your superior, inferior, or equal in Strength, Dexterity, Constitution, and Armor Class."
    }
  },
  {
