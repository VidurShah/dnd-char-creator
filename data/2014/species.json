  {
    "id": "2014/feature/trait-draconic-ancestry",
    "edition": "2014",
    "name": "Draconic Ancestry",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have draconic ancestry. Choose one type of dragon from the Draconic Ancestry table. Your breath weapon and damage resistance are determined by the dragon type, as shown in the table."
    }
  },
  {
    "id": "2014/feature/trait-breath-weapon",
    "edition": "2014",
    "name": "Breath Weapon",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You can use your action to exhale destructive energy. Your draconic ancestry determines the size, shape, and damage type of the exhalation.\n\nWhen you use your breath weapon, each creature in the area of the exhalation must make a saving throw, the type of which is determined by your draconic ancestry. The DC for this saving throw equals 8 + your Constitution modifier + your proficiency bonus. A creature takes 2d6 damage on a failed save, and half as much damage on a successful one. The damage increases to 3d6 at 6th level, 4d6 at 11th level, and 5d6 at 16th level.\n\nAfter you use your breath weapon, you cannot use it again until you complete a short or long rest."
    }
  },
  {
    "id": "2014/feature/trait-damage-resistance",
    "edition": "2014",
    "name": "Damage Resistance",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have resistance to the damage type associated with your draconic ancestry."
    }
  },
  {
    "id": "2014/feature/trait-darkvision",
    "edition": "2014",
    "name": "Darkvision",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have superior vision in dark and dim conditions. You can see in dim light within 60 feet of you as if it were bright light, and in darkness as if it were dim light. You cannot discern color in darkness, only shades of gray."
    }
  },
  {
    "id": "2014/feature/trait-dwarven-resilience",
    "edition": "2014",
    "name": "Dwarven Resilience",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have advantage on saving throws against poison, and you have resistance against poison damage."
    }
  },
  {
    "id": "2014/feature/trait-stonecunning",
    "edition": "2014",
    "name": "Stonecunning",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "Whenever you make an Intelligence (History) check related to the origin of stonework, you are considered proficient in the History skill and add double your proficiency bonus to the check, instead of your normal proficiency bonus."
    }
  },
  {
    "id": "2014/feature/trait-dwarven-combat-training",
    "edition": "2014",
    "name": "Dwarven Combat Training",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have proficiency with the battleaxe, handaxe, light hammer, and warhammer."
    }
  },
  {
    "id": "2014/feature/trait-tool-proficiency",
    "edition": "2014",
    "name": "Tool Proficiency",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You gain proficiency with the artisan's tools of your choice: smith's tools, brewer's supplies, or mason's tools."
    }
  },
  {
    "id": "2014/feature/trait-fey-ancestry",
    "edition": "2014",
    "name": "Fey Ancestry",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have advantage on saving throws against being charmed, and magic cannot put you to sleep."
    }
  },
  {
    "id": "2014/feature/trait-trance",
    "edition": "2014",
    "name": "Trance",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "Elves do not need to sleep. Instead, they meditate deeply, remaining semiconscious, for 4 hours a day. (The Common word for such meditation is \"trance.\") While meditating, you can dream after a fashion; such dreams are actually mental exercises that have become reflexive through years of practice. After resting this way, you gain the same benefit that a human does from 8 hours of sleep."
    }
  },
  {
    "id": "2014/feature/trait-keen-senses",
    "edition": "2014",
    "name": "Keen Senses",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have proficiency in the Perception skill."
    }
  },
  {
    "id": "2014/feature/trait-gnome-cunning",
    "edition": "2014",
    "name": "Gnome Cunning",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have advantage on all Intelligence, Wisdom, and Charisma saving throws against magic."
    }
  },
  {
    "id": "2014/feature/trait-skill-versatility",
    "edition": "2014",
    "name": "Skill Versatility",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You gain proficiency in two skills of your choice."
    }
  },
  {
    "id": "2014/feature/trait-savage-attacks",
    "edition": "2014",
    "name": "Savage Attacks",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "When you score a critical hit with a melee weapon attack, you can roll one of the weapon's damage dice one additional time and add it to the extra damage of the critical hit."
    }
  },
  {
    "id": "2014/feature/trait-relentless-endurance",
    "edition": "2014",
    "name": "Relentless Endurance",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "When you are reduced to 0 hit points but not killed outright, you can drop to 1 hit point instead. you cannot use this feature again until you finish a long rest."
    }
  },
  {
    "id": "2014/feature/trait-menacing",
    "edition": "2014",
    "name": "Menacing",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You gain proficiency in the Intimidation skill."
    }
  },
  {
    "id": "2014/feature/trait-brave",
    "edition": "2014",
    "name": "Brave",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have advantage on saving throw against being frightened."
    }
  },
  {
    "id": "2014/feature/trait-halfling-nimbleness",
    "edition": "2014",
    "name": "Halfling Nimbleness",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You can move through the space of any creature that is of a size larger than yours."
    }
  },
  {
    "id": "2014/feature/trait-lucky",
    "edition": "2014",
    "name": "Lucky",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "When you roll a 1 on the d20 for an attack roll, ability check, or saving throw, you can reroll the die and must use the new roll."
    }
  },
  {
    "id": "2014/feature/trait-hellish-resistance",
    "edition": "2014",
    "name": "Hellish Resistance",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have resistance to fire damage."
    }
  },
  {
    "id": "2014/feature/trait-infernal-legacy",
    "edition": "2014",
    "name": "Infernal Legacy",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You know the thaumaturgy cantrip. When you reach 3rd level, you can cast the hellish rebuke spell as a 2nd-level spell once with this trait and regain the ability to do so when you finish a long rest. When you reach 5th level, you can cast the darkness spell once with this trait and regain the ability to do so when you finish a long rest. Charisma is your spellcasting ability for these spells."
    }
  },
  {
    "id": "2014/feature/trait-dwarven-toughness",
    "edition": "2014",
    "name": "Dwarven Toughness",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "Your hit point maximum increases by 1, and it increases by 1 every time you gain a level."
    }
  },
  {
    "id": "2014/feature/trait-elf-weapon-training",
    "edition": "2014",
    "name": "Elf Weapon Training",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have proficiency with the longsword, shortsword, shortbow, and longbow."
    }
  },
  {
    "id": "2014/feature/trait-high-elf-cantrip",
    "edition": "2014",
    "name": "High Elf Cantrip",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You know one cantrip of your choice form the wizard spell list. Intelligence is your spellcasting ability for it."
    }
  },
  {
    "id": "2014/feature/trait-extra-language",
    "edition": "2014",
    "name": "Extra Language",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You can speak, read, and write one extra language of your choice."
    }
  },
  {
    "id": "2014/feature/trait-artificers-lore",
    "edition": "2014",
    "name": "Artificer's Lore",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "Whenever you make an Intelligence (History) check related to magic items, alchemical objects, or technological devices, you can add twice your proficiency bonus, instead of any proficiency bonus you normally apply."
    }
  },
  {
    "id": "2014/feature/trait-tinker",
    "edition": "2014",
    "name": "Tinker",
    "source": {
      "book": "SRD5.1"
    },
    "origin": "seed",
    "schemaVersion": 1,
    "kind": "feature",
    "data": {
      "description": "You have proficiency with artisan's tools (tinker's tools). Using those tools, you can spend 1 hour and 10 gp worth of materials to construct a Tiny clockwork device (AC 5, 1 hp). The device ceases to function after 24 hours (unless you spend 1 hour repairing it to keep the device functioning), or when you use your action to dismantle it; at that time, you can reclaim the materials used to create it. You can have up to three such devices active at a time.\n\nWhen you create a device, choose one of the following options:\n\nClockwork Toy: This toy is a clockwork animal, monster, or person, such as a frog, mouse, bird, dragon, or soldier. When placed on the ground, the toy moves 5 feet across the ground on each of your turns in a random direction. It makes noises as appropriate to the creature it represents.\n\nFire Starter: The device produces a miniature flame, which you can use to light a candle, torch, or campfire. Using the device requires your action.\n\nMusic Box: When opened, this music box plays a single song at a moderate volume. The box stops playing when it reaches the song's end or when it is closed."
    }
  },
